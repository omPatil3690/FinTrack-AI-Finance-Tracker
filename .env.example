NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Use NEXT_PUBLIC_DATABASE_URL to match current client-side DB usage.
# For safer server-side usage and migrations, also set DATABASE_URL.
NEXT_PUBLIC_DATABASE_URL=
DATABASE_URL=

# Optional: enables AI advice in the dashboard (server-side)
GEMINI_API_KEY=
# Optional: override Gemini model (default: gemini-2.5-flash)
GEMINI_MODEL=
